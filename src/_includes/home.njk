{% extends "layout.njk" %}
{% set t = strings[locale] %}
{% set apps = apps %}
{% block content %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Eagle Security",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Android",
  "description": "IMSI-catcher catcher. Smart anti-wiring application, fake base stations detecting.",
  "offers": [
    { "@type": "Offer", "url": "https://play.google.com/store/apps/details?id=com.integer.eaglesecurity_free", "name": "Eagle Security FREE" },
    { "@type": "Offer", "url": "https://play.google.com/store/apps/details?id=com.integer.eaglesecurity_unlim", "name": "Eagle Security UNLIMITED" }
  ],
  "author": { "@type": "Organization", "name": "Int64", "email": "eagle.app.project@gmail.com" }
}
</script>
<div class="home">
  <div class="home__logo-wrap">
    <img src="assets/img/logo.webp" alt="Eagle Security" class="home__logo-img" width="96" height="96" loading="eager">
  </div>
  <h1 class="home__title">Eagle Security</h1>
  <p class="home__tagline">{{ t.tagline }}</p>
  <div class="home__download-row">
    <a href="{{ apps[0].link }}" class="home__download-btn home__download-btn--outline" target="_blank" rel="noopener noreferrer">{{ t.download_free }}</a>
    <a href="{{ apps[1].link }}" class="home__download-btn home__download-btn--filled" target="_blank" rel="noopener noreferrer">{{ t.download_unlimited }}</a>
  </div>
  <p class="home__questions-hint">{{ t.questions_faq_before }}<a href="{{ baseUrl }}/faq/" class="home__faq-link">FAQ</a>{{ t.questions_faq_after }}</p>
</div>
{% endblock %}
