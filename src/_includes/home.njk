<script>
(function() {
  var items = document.querySelectorAll('.home__menu-link');
  var cur = -1;
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowDown') { cur = (cur + 1) % items.length; items[cur].focus(); e.preventDefault(); }
    if (e.key === 'ArrowUp') { cur = (cur - 1 + items.length) % items.length; items[cur].focus(); e.preventDefault(); }
    if (e.key === 'Enter' && cur >= 0) items[cur].click();
  });
  items.forEach(function(el, i) { el.addEventListener('focus', function() { cur = i; }); });
})();
</script>
